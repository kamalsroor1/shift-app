  "item": [
    {
      "name": "1. Authentication & Users",
      "description": "End-to-end authentication lifecycle including user registration, JSON/form login, JWT profile retrieval (/me), and token refreshing.",
      "item": [
        {
          "name": "Register Nurse Account",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201 Created or 409 Duplicate\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.test(\"User profile has valid UUID and role\", function () {",
                  "        pm.expect(jsonData.uuid).to.be.a('string');",
                  "        pm.expect(jsonData.role).to.eql(\"nurse\");",
                  "    });",
                  "    pm.environment.set(\"user_uuid\", jsonData.uuid);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Nurse Clara test\",\n  \"employee_id\": \"EMP-N101\",\n  \"phone\": \"{{nurse_phone}}\",\n  \"password\": \"password123\",\n  \"role\": \"nurse\",\n  \"department_code\": \"ICU\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register"
              ]
            }
          }
        },
