    {
      "name": "3. Family Links API",
      "description": "Lifecycle management of linking a Nurse account to a Partner account. Nurse initiates link -> Partner accepts link -> Status becomes ACTIVE.",
      "item": [
        {
          "name": "Initiate Family Link (Requires Nurse JWT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201 Created or 409 Conflict\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.test(\"Initial link status is PENDING\", function () {",
                  "        pm.expect(jsonData.status).to.eql(\"PENDING\");",
                  "    });",
                  "    pm.environment.set(\"link_uuid\", jsonData.uuid);",
                  "    console.log(\"Saved link_uuid to environment:\", jsonData.uuid);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"partner_phone\": \"{{partner_phone}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/family-links",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "family-links"
              ]
            }
          }
        },
        {
          "name": "List Associated Family Links",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "pm.test(\"Returns list of links\", function () {",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});",
                  "",
                  "if (jsonData.length > 0 && !pm.environment.get(\"link_uuid\")) {",
                  "    pm.environment.set(\"link_uuid\", jsonData[0].uuid);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/family-links",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "family-links"
              ]
            }
          }
        },
        {
          "name": "Accept Family Link (Requires Partner JWT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 OK or 400/403 (if already accepted/wrong user)\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 400, 403]);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.test(\"Status updated to ACTIVE\", function () {",
                  "        pm.expect(jsonData.status).to.eql(\"ACTIVE\");",
                  "        pm.expect(jsonData.linked_at).to.not.be.null;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/family-links/{{link_uuid}}/accept",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "family-links",
                "{{link_uuid}}",
                "accept"
              ]
            }
          }
        },
        {
          "name": "Revoke Family Link",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 OK or 400/403\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 400, 403]);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.test(\"Status changed to REVOKED\", function () {",
                  "        pm.expect(jsonData.status).to.eql(\"REVOKED\");",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/family-links/{{link_uuid}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "family-links",
                "{{link_uuid}}"
              ]
            }
          }
        }
      ]
    }
