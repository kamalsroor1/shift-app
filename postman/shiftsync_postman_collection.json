        {
          "name": "Get Current Profile (/me)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "pm.test(\"Profile matches active JWT user\", function () {",
                  "    pm.expect(jsonData).to.have.property(\"uuid\");",
                  "    pm.expect(jsonData).to.have.property(\"phone\");",
                  "    pm.expect(jsonData).to.have.property(\"department\");",
                  "});",
                  "",
                  "if (jsonData.uuid) {",
                  "    pm.environment.set(\"user_uuid\", jsonData.uuid);",
                  "}",
                  "if (jsonData.department && jsonData.department.uuid) {",
                  "    pm.environment.set(\"department_uuid\", jsonData.department.uuid);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "me"
              ]
            }
          }
        },
        {
          "name": "Refresh JWT Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access_token) {",
                  "    pm.environment.set(\"access_token\", jsonData.access_token);",
                  "    if (jsonData.refresh_token) {",
                  "        pm.environment.set(\"refresh_token\", jsonData.refresh_token);",
                  "    }",
                  "    console.log(\"Refreshed access_token stored in environment\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
