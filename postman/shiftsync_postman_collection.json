    {
      "name": "2. Departments API",
      "description": "CRUD operations for Departments. Listing and viewing is public/protected for users, while Creation and Target modification requires ADMIN role.",
      "item": [
        {
          "name": "List All Departments",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "pm.test(\"Response is an array of departments\", function () {",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "    pm.expect(jsonData.length).to.be.above(0);",
                  "});",
                  "",
                  "if (jsonData.length > 0) {",
                  "    pm.environment.set(\"department_uuid\", jsonData[0].uuid);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/departments",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "departments"
              ]
            }
          }
        },
